# agent-starter environment configuration
# Copy this to .env and fill in your values

# ── LLM Provider (default: ollama — no key needed) ───────────────────────────
# AGENT_PROVIDER=ollama          # ollama | anthropic | openai | google
# AGENT_MODEL=llama3.2           # model name for the chosen provider
# AGENT_TEMPERATURE=0.7

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI ────────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...

# ── Google Gemini ─────────────────────────────────────────────────────────────
# GOOGLE_API_KEY=...

# ── Ollama (local) ────────────────────────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434   # default

# ── Tools ─────────────────────────────────────────────────────────────────────
# TAVILY_API_KEY=tvly-...   # for web_search tool (optional)

# ── Memory ────────────────────────────────────────────────────────────────────
# AGENT_MEMORY_DIR=.agentkit          # where SQLite DBs are stored
# AGENT_LONG_TERM_MEMORY=true

# ── Server ────────────────────────────────────────────────────────────────────
# AGENT_SERVER_HOST=0.0.0.0
# AGENT_SERVER_PORT=8000
